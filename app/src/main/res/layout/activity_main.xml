<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧭"
            android:textSize="40sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VaultNavigator"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvIcon"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navigation et composants sécurisés"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Champ ID -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Identifiant de ressource"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilItemId"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Entrez un ID"
                    app:hintTextColor="@color/text_muted"
                    app:boxStrokeColor="@color/purple_primary"
                    app:boxBackgroundColor="@color/bg_card_dark"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etItemId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/text_primary"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section Intents -->
        <TextView
            android:id="@+id/tvIntentsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAVIGATION"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/cardInput"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/llIntents"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvIntentsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExplicitIntent"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📦  Intent Explicite"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImplicitIntent"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌐  Intent Implicite"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSingleTop"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔁  Tester SingleTop"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

        </LinearLayout>

        <!-- Section Composants -->
        <TextView
            android:id="@+id/tvComponentsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPOSANTS"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/llIntents"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/llComponents"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvComponentsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotification"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔔  Notification + PendingIntent"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnService"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="⚙️  Démarrer Service"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSecureActivity"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔐  Activité Sécurisée"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSecurityReport"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📋  Rapport de Sécurité"
                android:textSize="15sp"
                app:backgroundTint="@color/teal_accent"
                app:cornerRadius="14dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>